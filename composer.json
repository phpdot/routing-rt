    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "phpdot/routing": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
